# Required: wallet that is (or will be) registered on netuid 54.
WALLET_NAME=test-miner
WALLET_HOTKEY=miner-hot

# Subnet / chain settings.
NETUID=54
SUBTENSOR_NETWORK=finney
CHAIN_ENDPOINT=wss://entrypoint-finney.opentensor.ai:443

# Miner runtime settings.
MINER_MODEL_NAME=llama3.1:latest
OLLAMA_URL=http://127.0.0.1:11434
MINER_AXON_PORT=8091
# If behind NAT, set your public WAN IP and forwarded port.
# AXON_EXTERNAL_IP=your.public.ip
# AXON_EXTERNAL_PORT=8091
LOG_LEVEL=debug

# Optional Phase 4 settings.
# HF_TOKEN=hf_your_token
FLUX_DEVICE=cpu

# Paths (defaults shown).
MINER_ENV_PATH=/home/admina/MIID-subnet/miner_env
LOG_DIR=/home/admina/MIID-subnet/logs
RUN_DIR=/home/admina/MIID-subnet/run

# Extra optional miner args, separated by spaces.
# EXTRA_ARGS=--logging.trace

# Dashboard settings.
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8810
PORT_HEALTH_ENABLED=true
PORT_HEALTH_CHECK_SECONDS=60
PORT_HEALTH_FAILURE_THRESHOLD=1
PORT_HEALTH_RECOVERY_THRESHOLD=1
PORT_HEALTH_CONNECT_TIMEOUT_SECONDS=8
PORT_HEALTH_ALERT_COOLDOWN_MINUTES=30
PORT_HEALTH_IP_DISCOVERY_URLS=https://api.ipify.org,https://ifconfig.me/ip
PORT_HEALTH_CHECK_URL=https://ports.yougetsignal.com/check-port.php

# Telegram notifier
TELEGRAM_NOTIFIER_ENABLED=true
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_POLL_SECONDS=1.0
TELEGRAM_FLUSH_SECONDS=5.0
TELEGRAM_HEARTBEAT_SECONDS=300.0
TELEGRAM_NO_TRAFFIC_ALERT_MINUTES=20
TELEGRAM_NO_TRAFFIC_ALERT_COOLDOWN_MINUTES=30
TELEGRAM_MAX_LINES_PER_MESSAGE=60
TELEGRAM_MAX_CHARS_PER_MESSAGE=3500
